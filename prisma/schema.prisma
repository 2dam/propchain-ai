generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Property {
  id             String    @id @default(cuid())
  name           String
  address        String
  type           String
  price          Float
  area           Float
  builtYear      Int
  monthlyRent    Float
  maintenanceFee Float
  neighborhood   String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  analysis       Analysis?
  payments       Payment[]
}

model Analysis {
  id               String   @id @default(cuid())
  propertyId       String   @unique
  score            Int
  riskScore        Int      @default(50)
  summary          String
  marketAnalysis   String
  investmentReport String
  riskAnalysis     String
  createdAt        DateTime @default(now())
  property         Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  feedback         Feedback[]
}

model Feedback {
  id         String   @id @default(cuid())
  analysisId String
  value      String
  createdAt  DateTime @default(now())
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  payments     Payment[]
}

model Payment {
  id         String   @id @default(cuid())
  propertyId String
  userId     String?
  amount     Int
  status     String   @default("PAID")
  provider   String   @default("MVP")
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}
